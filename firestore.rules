// ============================================================
//  firestore.rules  —  Surtify / Teekhi & Co.
//  Deploy via:  firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // ── products ─────────────────────────────────────────────
    // Anyone can read products. Only admins can create/update/delete.
    match /products/{productId} {
      allow read:   if true;
      allow write:  if isAdmin();
    }

    // ── users ────────────────────────────────────────────────
    // Users can only read/write their OWN document.
    // Admins can read any user document (for order management).
    match /users/{userId} {
      allow read:   if isOwner(userId) || isAdmin();
      allow write:  if isOwner(userId);
    }

    match /orders/{orderId} {
      allow read, write: if true;
    }

    // ── authorized_admins ────────────────────────────────────
    // Only readable by admins. Used by the Cloud Function to
    // check if an email should receive an admin Custom Claim.
    match /authorized_admins/{adminId} {
      allow read:  if isAdmin();
      allow write: if false; // Managed only via Firebase Console
    }

    // ── admin_logs ───────────────────────────────────────────
    // Admins can create and read logs. Nobody can update or delete.
    match /admin_logs/{logId} {
      allow create: if isAdmin();
      allow read:   if isAdmin();
      allow update, delete: if false;
    }
  }
}
